{
    "name": "zentria",
    "version": "1.0.0",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev:api": "bun run --cwd apps/api dev",
        "dev:web": "bun run --cwd apps/web --bun dev",
        "db:generate": "bun run --cwd apps/api db:generate",
        "db:migrate": "bun run --cwd apps/api db:migrate",
        "db:studio": "bun run --cwd apps/api db:studio",
        "auth:generate": "bun run --cwd apps/api auth:generate"
    },
    "dependencies": {
        "better-auth": "^1.4.20",
        "zod": "^4.3.6"
    }
}